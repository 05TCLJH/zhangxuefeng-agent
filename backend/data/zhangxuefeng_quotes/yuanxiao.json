{
  "category": "yuanxiao",
  "quotes": [
    {
      "id": "zxf-yuanxiao-001",
      "text": "能上985就别去211，能上211就别去双非。学校层次就是你的第一张名片。",
      "tags": [
        "985",
        "211",
        "学校层次",
        "名片"
      ],
      "sentiment": "cautionary",
      "related_majors": []
    },
    {
      "id": "zxf-yuanxiao-002",
      "text": "兰州大学，985中的隐藏王者，性价比极高，分数低但实力强。",
      "tags": [
        "兰州大学",
        "985",
        "性价比",
        "被低估"
      ],
      "sentiment": "encouraging",
      "related_majors": []
    },
    {
      "id": "zxf-yuanxiao-003",
      "text": "哈工大威海，985的牌子、二线的分数，工科生的宝藏学校。",
      "tags": [
        "哈工大威海",
        "985",
        "性价比",
        "工科"
      ],
      "sentiment": "encouraging",
      "related_majors": [
        "机械工程",
        "计算机科学与技术"
      ]
    },
    {
      "id": "zxf-yuanxiao-004",
      "text": "东北大学，虽然地理位置吃亏，但自动化、计算机在全国都是顶级的。",
      "tags": [
        "东北大学",
        "985",
        "自动化",
        "计算机",
        "地理位置"
      ],
      "sentiment": "encouraging",
      "related_majors": [
        "自动化",
        "计算机科学与技术"
      ]
    },
    {
      "id": "zxf-yuanxiao-005",
      "text": "西北农林科技大学，985中分数最低的，但进去就是985的学历，考研、考公都好使。",
      "tags": [
        "西北农林",
        "985",
        "低分",
        "性价比",
        "考研"
      ],
      "sentiment": "encouraging",
      "related_majors": [
        "农学",
        "食品科学与工程"
      ]
    },
    {
      "id": "zxf-yuanxiao-006",
      "text": "中国海洋大学，985里面最容易被忽略的，海洋科学全国第一。",
      "tags": [
        "中国海洋大学",
        "985",
        "海洋科学",
        "被忽略"
      ],
      "sentiment": "encouraging",
      "related_majors": [
        "海洋科学",
        "水产"
      ]
    },
    {
      "id": "zxf-yuanxiao-007",
      "text": "上海大学，211里面的王者。在上海就是最大的优势，实习、就业机会碾压外省985。",
      "tags": [
        "上海大学",
        "211",
        "上海",
        "就业",
        "城市优势"
      ],
      "sentiment": "encouraging",
      "related_majors": []
    },
    {
      "id": "zxf-yuanxiao-008",
      "text": "南京理工、南京航空，军工背景的211，就业率高得吓人。",
      "tags": [
        "南京理工",
        "南京航空",
        "211",
        "军工",
        "就业率"
      ],
      "sentiment": "encouraging",
      "related_majors": [
        "兵器工程",
        "航空航天工程"
      ]
    },
    {
      "id": "zxf-yuanxiao-009",
      "text": "合肥工业大学，低调到没人知道，但工科就业杠杠的。中建、中铁每年招一大批。",
      "tags": [
        "合肥工大",
        "211",
        "工科",
        "就业",
        "低调"
      ],
      "sentiment": "encouraging",
      "related_majors": [
        "土木工程",
        "机械工程"
      ]
    },
    {
      "id": "zxf-yuanxiao-010",
      "text": "苏州大学，211里面进步最快的，地处苏州，产业发达，不愁就业。",
      "tags": [
        "苏州大学",
        "211",
        "苏州",
        "产业",
        "就业"
      ],
      "sentiment": "encouraging",
      "related_majors": []
    },
    {
      "id": "zxf-yuanxiao-011",
      "text": "宁去大城市的211，不去小城市的985。城市决定了你的眼界、实习和第一份工作。",
      "tags": [
        "城市",
        "211",
        "985",
        "眼界",
        "实习"
      ],
      "sentiment": "neutral",
      "related_majors": []
    },
    {
      "id": "zxf-yuanxiao-012",
      "text": "双一流不等于老985/211。有些新入选的双一流，社会认可度还没跟上来。",
      "tags": [
        "双一流",
        "985",
        "211",
        "社会认可"
      ],
      "sentiment": "cautionary",
      "related_majors": []
    },
    {
      "id": "zxf-yuanxiao-013",
      "text": "选学校也要看它的王牌专业。去了好学校但读了个烂专业，不如去差一档的学校读王牌专业。",
      "tags": [
        "王牌专业",
        "学校选择",
        "组合",
        "匹配"
      ],
      "sentiment": "neutral",
      "related_majors": []
    },
    {
      "id": "zxf-yuanxiao-014",
      "text": "能去省会就别去地级市。省会的资源、机会、人脉，地级市给不了你。",
      "tags": [
        "省会",
        "地级市",
        "资源",
        "机会"
      ],
      "sentiment": "neutral",
      "related_majors": []
    },
    {
      "id": "zxf-yuanxiao-015",
      "text": "独立学院和民办大学，能不去就不去。学费贵、社会认可低，出来找工作被歧视。",
      "tags": [
        "独立学院",
        "民办",
        "学费",
        "歧视",
        "就业"
      ],
      "sentiment": "cautionary",
      "related_majors": []
    },
    {
      "id": "zxf-yuanxiao-016",
      "text": "好的高职比烂三本强。深圳职业技术大学、金华职业技术学院，就业率比很多本科都高。",
      "tags": [
        "高职",
        "三本",
        "就业率",
        "深职",
        "性价比"
      ],
      "sentiment": "encouraging",
      "related_majors": []
    }
  ]
}